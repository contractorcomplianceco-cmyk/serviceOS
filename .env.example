# ServiceConnect with RoseOS Intelligence — environment variables
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Only variable names and safe placeholders belong in this file.

# ---------------------------------------------------------------------------
# Database (required) — PostgreSQL connection string used by the API server,
# Drizzle migrations (lib/db), and the seed script.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/serviceconnect

# ---------------------------------------------------------------------------
# API server (artifacts/api-server)
# ---------------------------------------------------------------------------
# Signs/verifies auth session tokens. Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Node environment: development | production | test
NODE_ENV=development
# Optional log level: fatal|error|warn|info|debug|trace (default: info)
LOG_LEVEL=info
# Credentialed CORS allowlist — comma-separated list of EXACT browser origins
# permitted to call the API with cookies. Matching is exact (scheme + host +
# port); no wildcards, no subdomain globbing, no trailing slash. Include the
# published frontend origin plus any local dev origins you use.
SERVICECONNECT_ALLOWED_ORIGINS=https://connect-bridge-swift.lovable.app,http://localhost:5173
# Password used by the seed script for the demo accounts it creates.
DEMO_PASSWORD=demo-password

# ---------------------------------------------------------------------------
# Object storage (file attachments / documents)
# Choose a backend: "local" (filesystem, good for local/Lovable dev) or
# "object" (Replit App Storage / GCS-compatible, used in production).
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
# For STORAGE_BACKEND=local — directory where uploaded files are written.
LOCAL_STORAGE_DIR=./.local-storage
# For STORAGE_BACKEND=object — Replit App Storage configuration.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ---------------------------------------------------------------------------
# Ports & routing — normally injected by the Replit workflow. Set only when
# running the services manually outside Replit.
# ---------------------------------------------------------------------------
# API server listen port (matches the value in artifact.toml).
# PORT=8080
# ServiceConnect web app base path and dev port.
# BASE_PATH=/
# PORT=24052

# Replit-only (safe to omit outside Replit).
# REPL_ID=
